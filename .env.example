# AWS credentials — set via `aws configure` or export directly
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Terragrunt state backend — created by `make aws-bootstrap`
# Bucket name is account-scoped: prism-tfstate-<your-account-id>
TF_STATE_BUCKET=prism-tfstate-
TF_LOCK_TABLE=prism-terraform-locks
